{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Mode": "IP",
    "MaxRequestsPerMinute": 100,
    "MaxRequestsPerHour": 1000
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "EndpointWhitelist": [
      "get:/health",
      "get:/metrics",
      "options:*"
    ],
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  },
  "ReverseProxy": {
    "Routes": {
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "roles-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/roles/{**catch-all}"
        }
      },
      "invitations-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/invitations/{**catch-all}"
        }
      },
      "login-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/login/{**catch-all}"
        }
      },
      "users-health-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/test-health"
        },
        "Transforms": [
          {
            "PathSet": "/health"
          }
        ]
      },
      "drug-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/drug/{**catch-all}"
        }
      },
      "pharmacy-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/pharmacy/{**catch-all}"
        }
      },
      "purchases-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/purchases/{**catch-all}"
        }
      },
      "stockrequest-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/stockrequest/{**catch-all}"
        }
      },
      "unitmeasure-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/unitmeasure/{**catch-all}"
        }
      },
      "presentation-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/presentation/{**catch-all}"
        }
      },
      "export-route": {
        "ClusterId": "pharmacy-cluster",
        "Match": {
          "Path": "/api/export/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://pharmago-users-service:80"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "pharmacy-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://pharmago-pharmacy-service:80"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": false,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}

